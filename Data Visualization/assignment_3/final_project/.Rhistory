library(plotly)
library(readxl)
# Read data from Excel file (adjust the path and sheet name accordingly)
data <- read_excel("gender_paygap.xlsx")
# Convert 'dates' to Date format if needed
data$dates <- as.Date(data$dates)
# Ensure 'state' is treated as a factor
data$state <- as.factor(data$state)
# Define date range
date_min <- as.Date("2012-05-01")
date_max <- as.Date("2024-01-31")
# Create base plot
base <- plot_ly(data, x = ~dates, y = ~gap, color = ~state, size = ~gap,
text = ~paste("State:", state, "<br>Date:", dates, "<br>Gap:", gap),
hoverinfo = "text") %>%
layout(
title = "Gender Pay Gap in Australia",
xaxis = list(title = "Year", tickformat = "%Y", range = c(date_min, date_max)),
yaxis = list(title = "Gap"),
showlegend = TRUE,
hovermode = "closest",
xaxis_type = "date"
)
# Add animation markers
animation <- base %>%
add_markers(frame = ~dates, ids = ~state) %>%
animation_opts(1000, easing = "elastic", redraw = FALSE) %>%
animation_button(
x = 1, xanchor = "right", y = 0, yanchor = "bottom"
) %>%
animation_slider(
currentvalue = list(prefix = "Date: ")
)
# Print the interactive plot
animation
